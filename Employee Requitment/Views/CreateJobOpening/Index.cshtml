@{
    ViewData["Title"] = "Create Job Opening";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>

    body {
        background: linear-gradient(135deg,#667eea,#764ba2);
        min-height: 100vh;
    }

    .form-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 10px;
    }

    .form-box {
        background: #fff;
        width: 100%;
        max-width: 1100px;
        padding: 35px;
        border-radius: 15px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }

    .form-header {
        border-bottom: 1px solid #eee;
        margin-bottom: 25px;
        padding-bottom: 10px;
    }

        .form-header h3 {
            font-weight: 700;
            color: #444;
        }

    .form-label {
        font-weight: 600;
        font-size: 14px;
    }

    .form-control, .form-select {
        border-radius: 8px;
        height: 42px;
    }

    textarea.form-control {
        height: 90px;
        resize: none;
    }

    .input-group-text {
        background: #f3f4f7;
    }

    .btn-submit {
        background: linear-gradient(45deg,#36d1dc,#5b86e5);
        border: none;
        padding: 10px 30px;
        font-weight: 600;
    }

    .btn-reset {
        background: #ff6b6b;
        border: none;
        padding: 10px 30px;
        font-weight: 600;
        color: white;
    }

</style>

<html>

<div class="form-container">

    <div class="form-box">

        <div class="form-header">
            <h3><i class="bi bi-briefcase"></i> Create Job Opening</h3>
        </div>

        <form asp-controller="JobOpening" asp-action="Create" method="post">

            <div class="row g-3">

                <div class="col-md-6">
                    <label class="form-label">Applied For</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-briefcase"></i></span>
                        <input type="text" name="AppliedFor" class="form-control" placeholder="Enter job title">
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Reporting Head</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input type="text" name="ReportingHead" class="form-control">
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Unit Name</label>
                    <input type="text" name="UnitName" class="form-control">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Location</label>
                    <input type="text" name="Location" class="form-control">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Qualification Required</label>
                    <input type="text" name="Qualification" class="form-control">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Type</label>
                    <select name="Type" class="form-select">
                        <option selected disabled>Select</option>
                        <option>Replacement</option>
                        <option>New</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Salary From</label>
                    <input type="number" name="SalaryFrom" class="form-control">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Salary To</label>
                    <input type="number" name="SalaryTo" class="form-control">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Job Description</label>
                    <textarea name="JobDescription" class="form-control"></textarea>
                </div>

            </div>

            <div class="text-center mt-4">

                <button type="submit" class="btn btn-submit text-white me-2">
                    <i class="bi bi-check-circle"></i> Submit
                </button>

                <button type="reset" class="btn btn-reset">
                    <i class="bi bi-x-circle"></i> Reset
                </button>

            </div>

        </form>

    </div>

</div>

</html>

