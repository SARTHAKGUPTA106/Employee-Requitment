@{
    ViewData["Title"] = "Create Job Opening";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="~/css/CREATENEWOPENING.css" />

<div class="container py-5">

    <div class="card shadow-sm mx-auto" style="max-width: 900px;">
        <div class="card-header bg-primary text-white d-flex align-items-center">
            <i class="bi bi-briefcase me-2 fs-4"></i>
            <h4 class="mb-0">Create Job Opening</h4>
        </div>

        <div class="card-body">
            <form asp-controller="JobOpening" asp-action="Create" method="post">

                <div class="row g-3">

                    <!-- Applied For -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Open Position For</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-briefcase"></i></span>
                            <input type="text" name="AppliedFor" class="form-control" placeholder="Enter job title" required>
                        </div>
                    </div>

                    <!-- Unit Name -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Unit Name</label>
                        <input type="text" name="UnitName" class="form-control" placeholder="Enter unit name" required>
                    </div>

                    <!-- Location -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Location</label>
                        <input type="text" name="Location" class="form-control" placeholder="Enter location" required>
                    </div>

                    <!-- Qualification -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Qualification Required</label>
                        <input type="text" name="Qualification" class="form-control" placeholder="E.g., Bachelor's in IT" required>
                    </div>

                    <!-- Type -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Type</label>
                        <select name="Type" class="form-select" required>
                            <option selected disabled>Select type</option>
                            <option>Replacement</option>
                            <option>New</option>
                        </select>
                    </div>

                    <!-- Salary -->
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Salary From</label>
                        <input type="number" name="SalaryFrom" class="form-control" placeholder="Min salary" min="0">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Salary To</label>
                        <input type="number" name="SalaryTo" class="form-control" placeholder="Max salary" min="0">
                    </div>

                    <!-- Job Description -->
                    <div class="col-12">
                        <label class="form-label fw-bold">Job Description</label>
                        <textarea name="JobDescription" class="form-control" rows="4" placeholder="Write job description..." required></textarea>
                    </div>

                    <!-- Experience -->
                    <div class="col-12">
                        <label class="form-label fw-bold">Experience (Years)</label>
                        <div class="d-flex align-items-center gap-3">
                            <input type="range" id="points" name="points" min="0" max="35" step="1" class="form-range experience-slider flex-grow-1">
                            <span id="pointsValue" class="fw-bold">5</span>
                        </div>
                        <div class="d-flex justify-content-between experience-ticks">
                            <!-- Generate ticks from 0 to 35 every 5 years -->
                            <span>0</span><span>5</span><span>10</span><span>15</span><span>20</span><span>25</span><span>30</span><span>35</span>
                        </div>
                    </div>

                </div>

                <!-- Buttons -->
                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-check-circle me-1"></i> Submit
                    </button>
                    <button type="reset" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Reset
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    const pointsInput = document.getElementById('points');
    const pointsValue = document.getElementById('pointsValue');

    function updateSlider() {
        pointsValue.textContent = pointsInput.value;
        const percent = (pointsInput.value - pointsInput.min) / (pointsInput.max - pointsInput.min) * 100;
        pointsInput.style.background = `linear-gradient(to right, #0d6efd 0%, #0d6efd ${percent}%, #dee2e6 ${percent}%, #dee2e6 100%)`;
    }

    pointsInput.addEventListener('input', updateSlider);
    updateSlider(); // Initialize on page load
</script>

