@{
    ViewData["Title"] = "CandidateShortlisting_InterviewProcess";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Interview Shortlisting</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>

        body {
            background: #f2f5ff;
            font-family: 'Segoe UI',sans-serif;
        }

        .header {
            background: linear-gradient(90deg,#4facfe,#00f2fe);
            color: white;
            padding: 15px 30px;
            font-size: 22px;
            font-weight: 600;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        }

        .section-card {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            margin-bottom: 20px;
        }

        .section-title {
            font-weight: 600;
            color: #333;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .step-badge {
            background: #667eea;
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 13px;
        }

        .form-label {
            font-weight: 600;
            font-size: 14px;
        }

        .form-control, .form-select {
            border-radius: 8px;
            height: 42px;
        }

        textarea {
            height: 80px;
            resize: none;
        }

        .btn-main {
            background: linear-gradient(45deg,#667eea,#764ba2);
            border: none;
            padding: 10px 25px;
            font-weight: 600;
        }

            .btn-main:hover {
                opacity: 0.9;
            }

        .btn-secondary {
            padding: 10px 20px;
        }

    </style>

</head>

<body>

    <div class="container mt-4">

        <form>

            <!-- STEP 1 -->

            <div class="section-card">

                <div class="section-title">
                    <span class="step-badge">Step 1</span>
                    <i class="bi bi-telephone"></i>
                    VC / Telephonic Interview
                </div>

                <div class="row g-3">

                    <div class="col-md-3">
                        <label class="form-label">Interview Date</label>
                        <input type="date" class="form-control">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Interview Time</label>
                        <input type="time" class="form-control">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Attendance</label>
                        <select class="form-select">
                            <option>Select</option>
                            <option>Attended</option>
                            <option>Reschedule</option>
                            <option>Not Attended</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <select class="form-select">
                            <option>Select</option>
                            <option>Reject</option>
                            <option>Hold</option>
                            <option>Under Discussion</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" class="btn btn-primary w-100">
                            Select for VC / Telephonic
                        </button>
                    </div>

                </div>

            </div>

            <!-- STEP 2 -->

            <div class="section-card">

                <div class="section-title">
                    <span class="step-badge">Step 2</span>
                    <i class="bi bi-people"></i>
                    Interview Panel
                </div>

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label">Interviewer Name</label>
                        <input type="text" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Panel</label>
                        <select class="form-select">
                            <option>Panel 1</option>
                            <option>Panel 2</option>
                            <option>Panel 3</option>
                            <option>Panel 4</option>
                            <option>Panel 5</option>
                        </select>
                    </div>

                </div>

            </div>

            <!-- STEP 3 -->

            <div class="section-card">

                <div class="section-title">
                    <span class="step-badge">Step 3</span>
                    <i class="bi bi-clipboard-check"></i>
                    Interview Result
                </div>

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <select class="form-select">
                            <option>Select</option>
                            <option>Reject</option>
                            <option>Hold</option>
                            <option>Under Discussion</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Upload Remarks</label>
                        <input type="file" class="form-control">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Discussion With</label>
                        <input type="text" class="form-control" placeholder="If Hold / Discussion">
                    </div>

                </div>

            </div>

            <!-- STEP 4 -->

            <div class="section-card">

                <div class="section-title">
                    <span class="step-badge">Step 4</span>
                    <i class="bi bi-building"></i>
                    Face to Face Interview
                </div>

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Time</label>
                        <input type="time" class="form-control">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <select class="form-select">
                            <option>Select</option>
                            <option>Reject</option>
                            <option>Hold</option>
                            <option>Under Discussion</option>
                        </select>
                    </div>

                </div>

            </div>

            <!-- STEP 5 -->

            <div class="section-card">

                <div class="section-title">
                    <span class="step-badge">Step 5</span>
                    <i class="bi bi-award"></i>
                    Final Decision
                </div>

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">Final Status</label>
                        <select class="form-select">
                            <option>Select</option>
                            <option>Reject</option>
                            <option>Hold</option>
                            <option>Under Discussion</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Upload Final Remarks</label>
                        <input type="file" class="form-control">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Date of Joining</label>
                        <input type="date" class="form-control">
                    </div>

                </div>

            </div>

            <div class="text-center mb-5">

                <button class="btn btn-main text-white me-2">
                    <i class="bi bi-save"></i> Save Process
                </button>

                <button type="reset" class="btn btn-secondary">
                    Reset
                </button>

            </div>

        </form>

    </div>

</body>
</html>