@{
    ViewData["Title"] = "Sourcing & Screening";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>

    .form-box {
        background: white;
        width: 95%;
        max-width: 1200px;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.2);
    }

    .title {
        font-weight: 700;
        color: #444;
    }

    .table thead {
        background: #667eea;
        color: white;
    }

    .badge-exp {
        background: #36cfc9;
    }

    .badge-notice {
        background: #ff9f43;
    }

    .search-box {
        max-width: 280px;
    }

</style>


