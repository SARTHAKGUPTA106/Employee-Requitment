@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <div class="row g-3">

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h4 class="text-primary">12</h4>
                    <p class="text-muted mb-0">Total Job Openings</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h4 class="text-success">35</h4>
                    <p class="text-muted mb-0">Total Candidates</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h4 class="text-warning">10</h4>
                    <p class="text-muted mb-0">Shortlisted</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h4 class="text-danger">5</h4>
                    <p class="text-muted mb-0">Positions Closed</p>
                </div>
            </div>
        </div>

    </div>



    <div class="card mt-4 shadow-sm border-0">

        <div class="card-header bg-white">
            <h6 class="mb-0">Recruitment Pipeline</h6>
        </div>

        <div class="card-body">

            <div class="progress" style="height:25px">

                <div class="progress-bar bg-info" style="width:25%">
                    Sourcing
                </div>

                <div class="progress-bar bg-warning" style="width:25%">
                    Shortlisting
                </div>

                <div class="progress-bar bg-primary" style="width:25%">
                    Interview
                </div>

                <div class="progress-bar bg-success" style="width:25%">
                    Offer / Closed
                </div>

            </div>

        </div>

    </div>


    <!-- RECENT CANDIDATES -->

    <div class="card mt-4 shadow-sm border-0">

        <div class="card-header bg-white">
            <h6 class="mb-0">Recent Candidates</h6>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>
                            <th>Candidate Name</th>
                            <th>Position</th>
                            <th>Experience</th>
                            <th>Status</th>
                            <th>Interview Date</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td>Abhinav Agarwal</td>
                            <td>Accounts Head</td>
                            <td>13 Years</td>
                            <td>
                                <span class="badge bg-warning">Shortlisted</span>
                            </td>
                            <td>12 Jun</td>
                        </tr>

                        <tr>
                            <td>Rajiv Gupta</td>
                            <td>Finance Manager</td>
                            <td>14 Years</td>
                            <td>
                                <span class="badge bg-primary">Interview</span>
                            </td>
                            <td>14 Jun</td>
                        </tr>

                        <tr>
                            <td>Rishabh Kumar</td>
                            <td>AGM Accounts</td>
                            <td>12 Years</td>
                            <td>
                                <span class="badge bg-success">Selected</span>
                            </td>
                            <td>10 Jun</td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>